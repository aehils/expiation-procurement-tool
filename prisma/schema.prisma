// Prisma schema for the Expiation procurement tool.
//
// Notes on id vs rfqNumber on Rfq:
//   `id` is an opaque cuid used internally (URLs, FK joins).
//   `rfqNumber` is the human-facing reference staff quote in emails/printouts.
//   Keeping both is the standard business-document pattern.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  // Placeholder only — the libsql driver adapter in prisma.config.ts and
  // src/lib/db.ts handles the real connection to Turso.
  url      = "file:./dev.db"
}

model Rfq {
  id        String   @id @default(cuid())
  rfqNumber String   @unique
  requester String
  status    String   @default("draft") // draft | details | quoted | ordered
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items          RfqItem[]
  purchaseOrders PurchaseOrder[]
  quote          Quote?
}

// A saved, configurable view of an RFQ's items. Kept deliberately light: we
// persist only the field selection (which columns, which items, the markup),
// not a copy of the item data. The live RfqItem rows are the source of truth;
// `config` just records how to present them when viewing or exporting.
model Quote {
  id          String   @id @default(cuid())
  quoteNumber String   @unique // human-facing ref, derived from rfqNumber (QU-…)
  rfqId       String   @unique // one quote per RFQ
  rfq         Rfq      @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  config      String // JSON: { columns: ColKey[]; items: string[]; markup: number }
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model RfqItem {
  id    String @id @default(cuid())
  rfqId String
  rfq   Rfq    @relation(fields: [rfqId], references: [id], onDelete: Cascade)

  // First-stage fields (captured on the entry view). Category/department are
  // optional so spreadsheet uploads can land them blank; the user still has
  // the choosers on the manual form to set them when they want to.
  itemCategory    String?
  department      String?
  itemName        String
  itemDescription String?
  requestQuantity Float
  size            String?
  specification   String?
  brand           String?
  model           String?
  additionalNotes String?

  // Second-stage fields (filled on the details view)
  mProductCode           String?
  unitQuantity           Float?
  uom                    String?
  manufacturerName       String?
  vendor                 String?
  vendorLocation         String?
  productLink            String?
  countryOfOrigin        String?
  vendorDeliveryTimeline String?
  originalCurrency       String?
  ogUnitPrice            Float?
  nairaUnitPrice         Float?
  nairaOverridden        Boolean @default(false)
  tax                    Float?
  taxMode                String? // "amount" | "percent"
  domesticShippingCost   Float?
  domesticShippingNaira  Float?
  intlShippingCost       Float?
  intlShippingNaira      Float?
  markedComplete         Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  poItems PoItem[]
}

model PurchaseOrder {
  id           String   @id @default(cuid())
  poNumber     String   @unique
  rfqId        String
  rfq          Rfq      @relation(fields: [rfqId], references: [id])
  status       String   @default("draft") // draft | issued | closed
  notes        String?
  markupFactor Float
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  items PoItem[]
}

model PoItem {
  id        String        @id @default(cuid())
  poId      String
  po        PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  rfqItemId String
  rfqItem   RfqItem       @relation(fields: [rfqItemId], references: [id])

  itemName              String
  itemCategory          String
  department            String
  vendor                String
  vendorLocation        String?
  brand                 String?
  mProductCode          String?
  manufacturerName      String?
  uom                   String?
  countryOfOrigin       String?
  vendorDeliveryTimeline String?

  quantity              Float

  nairaUnitPrice        Float
  taxAmount             Float?
  domesticShippingNaira Float?
  intlShippingNaira     Float?
  totalPerUnit          Float
  lineTotal             Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Snapshot of the latest NGN exchange rate per base currency. Written by the
// "Update" action on the details view so every user sees the same last-pulled
// timestamp, and so the banner doesn't start blank on page load.
model CurrencyRate {
  code      String   @id
  rate      Float
  fetchedAt DateTime
  updatedAt DateTime @updatedAt
}
